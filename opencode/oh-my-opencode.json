{
	"$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
	"disabled_hooks": [
		"anthropic-context-window-limit-recovery"
	],
	"claude_code": {
		"mcp": false,
		"commands": false,
		"skills": false,
		"agents": false,
		"hooks": false,
		"plugins": false
	},
	"sisyphus_agent": {
		"disabled": false,
		"default_builder_enabled": true,
		"planner_enabled": true,
		"replace_plan": true
	},
	"git_master": {
		"commit_footer": false,
		"include_co_authored_by": false
	},
	"google_auth": false,
	"agents": {
		"sisyphus": {
			"model": "quotio-openai/gpt-5.4",
			"variant": "high",
			"temperature": 0.1,
			"prompt_append": "ALWAYS USE THE QUESTION TOOL IF YOU NEED TO ASK USER.",
			"permission": {
				"question": "allow"
			}
		},
		"atlas": {
			"model": "quotio-openai/gpt-5.4",
			"variant": "medium",
			"temperature": 0.1,
			"prompt_append": "ALWAYS USE THE QUESTION TOOL IF YOU NEED TO ASK USER."
		},
		"oracle": {
			"model": "quotio-openai/gpt-5.4",
			"variant": "high"
		},
		"prometheus": {
			"model": "quotio-openai/gpt-5.4",
			"variant": "high",
			"prompt_append": "ALWAYS USE THE QUESTION TOOL IF YOU NEED TO ASK USER.",
			"permission": {
				"question": "allow"
			}
		},
		"librarian": {
			"model": "anthropic/claude-haiku-4-5"
		},
		"explore": {
			"model": "kimi-for-coding/k2p5"
		},
		"multimodal-looker": {
			"model": "quotio-openai/gpt-5.4",
			"variant": "medum"
		},
		"metis": {
			"model": "quotio-openai/gpt-5.4",
			"variant": "high",
			"prompt_append": "ALWAYS USE THE QUESTION TOOL IF YOU NEED TO ASK USER.",
			"permission": {
				"question": "allow"
			}
		},
		"momus": {
			"model": "quotio-openai/gpt-5.4",
			"variant": "xhigh"
		},
		"hephaestus": {
			"model": "quotio-openai/gpt-5.3-codex"
		}
	},
	"categories": {
		"visual-engineering": {
			"model": "anthropic/claude-opus-4-6",
			"temperature": 0.7
		},
		"ultrabrain": {
			"model": "quotio-openai/gpt-5.3-codex",
			"variant": "xhigh",
			"temperature": 0.1
		},
		"deep": {
			"model": "quotio-openai/gpt-5.3-codex",
			"variant": "high",
			"temperature": 0.1
		},
		"artistry": {
			"model": "anthropic/claude-opus-4-6",
			"temperature": 0.7
		},
		"quick": {
			"model": "quotio-openai/gpt-5.3-codex",
			"variant": "medium"
		},
		"unspecified-high": {
			"model": "quotio-openai/gpt-5.4",
			"variant": "high",
			"temperature": 0.1
		},
		"unspecified-low": {
			"model": "quotio-openai/gpt-5.3-codex",
			"temperature": 0.3
		},
		"writing": {
			"model": "anthropic/claude-opus-4-6"
		}
	},
	"_migrations": [
		"model-version:anthropic/claude-sonnet-4-5->anthropic/claude-sonnet-4-6"
	]
}